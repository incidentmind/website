<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — IncidentMind Blog</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="https://incidentmind.com{{ page.url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/img/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/img/favicon-32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/img/favicon-16.png" sizes="16x16" type="image/png">
  <link rel="apple-touch-icon" href="/img/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  {% render "partials/gtm-head.liquid", gtmId: site.gtm.id %}
</head>
<body>
  {% render "partials/gtm-body.liquid", gtmId: site.gtm.id %}
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <div class="aurora" aria-hidden="true">
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
  </div>

  <nav class="navbar scrolled" role="navigation" aria-label="Main navigation">
    <div class="navbar-inner">
      <a href="/" class="nav-logo" aria-label="IncidentMind home">
        <div class="nav-logo-icon"><img src="/img/icon.svg" alt="IncidentMind icon" width="40" height="40" style="display:block;"></div>
        <span class="nav-logo-text">IncidentMind</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <i class="fa-solid fa-bars"></i>
      </button>
      <ul class="nav-links">
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/#services">Solutions</a></li>
        <li><a href="/#open-source">Open Source</a></li>
        <li><a href="/#contact" class="nav-cta">Talk to IncidentMind</a></li>
      </ul>
    </div>
  </nav>

  <main id="main-content" class="blog-page">
    <section class="blog-post-hero">
      <div class="container blog-post-hero-inner">
        <a href="/blog/" class="blog-breadcrumb"><i class="fa-solid fa-arrow-left"></i> Back to blog</a>
        <div class="section-label">IncidentMind Blog</div>
        <h1>{{ title }}</h1>
        <p class="blog-post-subtitle">{{ description }}</p>
        <div class="blog-meta">
          {% if series %}<span class="blog-meta-pill">{{ series }}</span>{% endif %}
          {% if part %}<span class="blog-meta-pill">Part {{ part }}</span>{% endif %}
          <span class="blog-meta-pill">{{ date | date: "%b %d, %Y" }}</span>
          {% if readTime %}<span class="blog-meta-pill">{{ readTime }}</span>{% endif %}
        </div>
      </div>
    </section>

    <section class="blog-post-section">
      <div class="container">
        <article class="blog-post-article glass article-prose">
          {{ content }}
        </article>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-copy">© 2026 IncidentMind LLC. All rights reserved.</div>
        <div class="footer-links">
          <a href="https://github.com/borgius" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
          <a href="https://www.linkedin.com/company/incidentmind" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
          <a href="https://x.com/IncidentMind" target="_blank" rel="noopener" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
